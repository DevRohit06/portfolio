# GitHub API Token for fetching repository data
# Get one at: https://github.com/settings/tokens/new
# Required scope: public_repo
GITHUB_ACCESS_TOKEN=your_github_token_here

# Optional: Google Analytics Tracking ID
PUBLIC_GOOGLE_TAG_KEY=G-XXXXXXXXXX

# These are auto-injected by Vercel, only needed for local development
PUBLIC_VERCEL_URL=localhost:4321
PUBLIC_VERCEL_PROJECT_PRODUCTION_URL=your-project.vercel.app
PUBLIC_VERCEL_ENV=development
